# DeepSeek (https://api-docs.deepseek.com/)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-replace-me
LLM_CHAT_MODEL=deepseek-v4-flash

# Azure Speech (Round 16+ only - leave blank otherwise)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# Auth (Round 22+). JWT_SECRET is a real secret - generate one, e.g.:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-min-32-bytes
JWT_EXPIRY_DAYS=7
# Google OAuth Web client id (public). Same value used by backend + frontend.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Production domain used by Caddy to provision HTTPS certificates.
DOMAIN=kanhim0105.com
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://kanhim0105.com,https://www.kanhim0105.com
LETTER_ALLOWED_EMAILS=nguoiyeukimhan
VITE_LETTER_ALLOWED_EMAILS=nguoiyeukimhan

# Optional private single-account mode.
SINGLE_USER_ENABLED=false
SINGLE_USER_USERNAME=
SINGLE_USER_PASSWORD=
SINGLE_USER_DISPLAY_NAME=Learner
